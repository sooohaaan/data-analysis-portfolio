        <relation type='collection'>
          <relation connection='postgres.1qfp96h043i2ag1h4mh93024tkel' name='사용자 지정 SQL 쿼리' type='text'>SELECT
    app_name,
    ROUND(AVG(rating),2) AS avg_rating,
    COUNT(*) AS review_count,
    ROUND(SUM(CASE WHEN sentiment_label=&apos;negative&apos; THEN 1.0 ELSE 0 END)
          /COUNT(*)*100, 1) AS neg_pct
FROM app_reviews
GROUP BY app_name
ORDER BY avg_rating DESC</relation>
          <relation connection='postgres.1qfp96h043i2ag1h4mh93024tkel' name='app_reviews' table='[public].[app_reviews]' type='table' />
